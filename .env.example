# Optional: absolute base URL of the backend API.
#
# Leave UNSET in local development - the Vite dev server proxies /api/*
# to http://localhost:8000 via `vite.config.ts`.
#
# Set in production deployments where the SPA and API live on different
# origins (e.g. Vercel + Railway). Vite inlines this at build time.
#
# Example:
# VITE_API_BASE_URL=https://image-diff-backend-production.up.railway.app
